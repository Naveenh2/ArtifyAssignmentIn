// Peblo Notes — PostgreSQL schema via Prisma
// User owns notes and tags; notes link to tags through NoteTag; shares are public slugs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  notes        Note[]
  tags         Tag[]
  aiUsages     AIUsage[]
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteTags  NoteTag[]

  @@unique([userId, name])
  @@index([userId])
}

model Note {
  id         String      @id @default(cuid())
  title      String      @default("Untitled")
  content    String      @default("")
  archived   Boolean     @default(false)
  category   String?
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteTags   NoteTag[]
  shared     SharedNote?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId, updatedAt])
  @@index([userId, archived])
}

model NoteTag {
  noteId String
  tagId  String
  note   Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}

model SharedNote {
  id        String   @id @default(cuid())
  shareId   String   @unique
  noteId    String   @unique
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum AIUsageType {
  SUMMARY
  ACTION_ITEMS
  TITLE
  COMBINED
}

model AIUsage {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AIUsageType
  model     String?
  createdAt DateTime    @default(now())

  @@index([userId, createdAt])
}
