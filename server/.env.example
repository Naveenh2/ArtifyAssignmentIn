# -----------------------------------------------------------------------------
# DATABASE_URL — must be a REAL host (never leave "HOST" or "USER" as text)
# -----------------------------------------------------------------------------
# Neon: Project dashboard → "Connection string" → copy the full postgresql:// URL
#       (host looks like ep-cool-name-123456.us-east-2.aws.neon.tech)
#
# Local Postgres (example):
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/peblo_notes?schema=public"
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-NEON-HOST.neon.tech/neondb?sslmode=require"

JWT_SECRET="generate-a-long-random-string"
JWT_EXPIRES_IN="7d"
PORT=4000
CLIENT_ORIGIN="http://localhost:3000"
COOKIE_SECURE=false

# AI — Gemini is the primary integration for this assignment; OpenAI is optional fallback
GEMINI_API_KEY=""
OPENAI_API_KEY=""
